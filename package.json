{
  "name": "tagalong",
  "version": "0.0.1",
  "description": "A Progressive Web App for learning and sharing barbershop tags",
  "private": true,
  "scripts": {
    "build": "node scripts/generate-tags.js && vite build",
    "dev": "node scripts/generate-tags.js && vite dev",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "generate-tags": "node scripts/generate-tags.js"
  },
  "devDependencies": {
    "@sveltejs/adapter-cloudflare": "^7.2.3",
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.20.0",
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "autoprefixer": "^10.4.14",
    "eslint": "^8.28.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-svelte": "^2.46.0",
    "postcss": "^8.4.24",
    "prettier": "^3.0.0",
    "prettier-plugin-svelte": "^3.2.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^3.3.2",
    "tslib": "^2.4.1",
    "typescript": "^5.0.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@tonejs/midi": "^2.0.28",
    "fflate": "^0.8.2",
    "fuse.js": "^7.0.0",
    "gray-matter": "^4.0.3",
    "html-to-image": "^1.11.11",
    "idb": "^8.0.0",
    "marked": "^9.1.6",
    "nord": "^0.2.1"
  },
  "type": "module"
}
