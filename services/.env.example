# --- Catalog bot (GitHub Contents API) ---------------------------------------
# Fine-grained PAT for the bot account. Scope: Contents read/write on the
# catalog repo ONLY. This token lives only on the server — never in the client.
GITHUB_TOKEN=

# owner/repo holding the catalog (data/tags/*.md)
GITHUB_REPO=user/numtags

# Branch commits land on. Default: main (direct, wiki-style — see README).
CATALOG_BRANCH=main

# Directory inside the repo containing the tag .md files.
CATALOG_PATH=data/tags

# --- Rate limiting (in-memory, per client IP, sliding window) -----------------
# Reads (catalog GETs, proxy):
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
# Writes (catalog PUT/POST, /omr — the expensive/abusable ones):
RATE_LIMIT_WRITE_REQUESTS=10

# --- OMR ----------------------------------------------------------------------
# Command that runs the homr CLI. "uvx homr" resolves it on demand; use plain
# "homr" if you baked `pip install homr` into the image.
HOMR_CMD=uvx homr
# Generous timeout — transformer OMR on CPU is slow.
HOMR_TIMEOUT_SECONDS=300

# --- HTTP ----------------------------------------------------------------------
# Comma-separated origins allowed by CORS (the SvelteKit app).
ALLOWED_ORIGINS=http://localhost:5173
